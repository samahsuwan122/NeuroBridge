# ---------------------------------------------------------------------------
# NeuroBridge .gitignore
# ---------------------------------------------------------------------------

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.python-version
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Local databases ---
*.db
*.sqlite
*.sqlite3
neurobridge_dev.db

# --- Node / Web (React + Vite) ---
node_modules/
web/dist/
web/build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Flutter / Dart (mobile) ---
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/build/
mobile/.pub-cache/
mobile/.pub/
*.iml
*.lock.bak

# --- IDE / editors ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- OS files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log
logs/

# --- Generated files: storage, uploads, PDF reports ---
storage/
uploads/
*.pdf
!docs/**/*.pdf

# Keep the Memory Album upload folder in the repo (via .gitkeep) but never track
# the runtime uploaded images themselves.
!backend/storage/
backend/storage/*
!backend/storage/memory_uploads/
backend/storage/memory_uploads/*
!backend/storage/memory_uploads/.gitkeep
!backend/storage/provider_photos/
backend/storage/provider_photos/*
!backend/storage/provider_photos/.gitkeep
